// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AvailabilityStatus {
  available
  unavailable
}

model AvailabilityEntry {
  id     String             @id @default(cuid())
  day    Int
  status AvailabilityStatus
}

// Temp model for Event 
model Event {
  id String @id @default(uuid())
  name String
  checklist Checklist? // 1-to-1 relationship (not an actual table column)
}

// Model for Checklist group
model Checklist {
  id String @id @default(uuid())
  eventId String? @unique // (FK) ensures only 1 checklist per event, enforcing 1-to-1
  event Event? @relation(fields: [eventId], references: [id]) // references id column in Event table
  items ChecklistItem[] // 1-to-many
}

// Model for Checklist items
model ChecklistItem {
  id String @id @default(uuid())
  checklistId String // FK to Checklist table
  checklist Checklist @relation(fields: [checklistId], references: [id])
  item String
  completed Boolean @default(false)
}